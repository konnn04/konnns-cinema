# KKPhim (phimapi.com) API base URL. Change this if you ever point the app at a
# different mirror/instance of the same API.
NEXT_PUBLIC_API_BASE_URL="https://phimapi.com"

# Base URL used to resolve relative poster/thumbnail paths returned by the API.
NEXT_PUBLIC_IMAGE_CDN_URL="https://phimimg.com/upload/vod/"

# Public site URL (used for share links, canonical URLs, OG metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Site display name shown in metadata/branding.
NEXT_PUBLIC_SITE_NAME="Konnn's Cinema"

# Site-wide password gate (server-only, never exposed to the client). When
# empty/unset, the gate is fully disabled and the site behaves normally.
# When set, every route except /access and /api/site-auth is blocked behind
# a generic "no permission" page until the visitor enters this code at
# /access. See proxy.ts and lib/siteAuth.ts.
PASSWORD=""

# Watch Party real-time backend: Firebase Realtime Database. The browser talks
# to Firebase directly (no custom server needed, works on Vercel as-is). Get
# these values from Firebase Console > Project Settings > General > Your apps
# (Web app config). Also enable Authentication > Sign-in method > Anonymous,
# and Realtime Database (create it, then publish the rules from
# lib/watchParty/database.rules.json).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_DATABASE_URL=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
