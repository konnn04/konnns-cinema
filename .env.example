# KKPhim (phimapi.com) API base URL. Change this if you ever point the app at a
# different mirror/instance of the same API.
NEXT_PUBLIC_API_BASE_URL="https://phimapi.com"

# Base URL used to resolve relative poster/thumbnail paths returned by the API.
NEXT_PUBLIC_IMAGE_CDN_URL="https://phimimg.com/upload/vod/"

# Public site URL (used for share links, canonical URLs, OG metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Site display name shown in metadata/branding.
NEXT_PUBLIC_SITE_NAME="Konnn's Cinema"
